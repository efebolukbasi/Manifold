{
  "name": "@manifold/cli",
  "version": "0.1.0",
  "description": "Manifold CLI — the unified AI terminal interface",
  "type": "module",
  "bin": {
    "manifold": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
