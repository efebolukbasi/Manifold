    "@manifold/adapter-claude": "workspace:*",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "@iarna/toml": "^2.2.5",
    "chalk": "^5.4.1",
    "figures": "^6.1.0"
